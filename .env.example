STORAGE_BUCKET=scout-dev.appspot.com
GEOCODING_API_KEY=your_key_here
FIREBASE_CREDENTIALS_PATH=./service-account.json
ENV=dev
MAX_PHOTO_BYTES=10485760
CORS_ORIGINS=["*"]
# AI review summaries (Google Gemini). Secret Manager in prod. Leave blank to
# disable generation (the app still boots; summaries stay null).
GEMINI_API_KEY=your_gemini_key_here
# GEMINI_MODEL=gemini-2.0-flash-lite
